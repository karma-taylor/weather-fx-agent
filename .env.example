# ========== 方案 1：OpenAI 官方（需绑卡/有余额）==========
OPENAI_API_KEY=your_api_key_here
OPENAI_BASE_URL=https://api.openai.com/v1
MODEL=gpt-4o-mini

# ========== 方案 2：Groq（注册后有免费额度，兼容 OpenAI 接口；需能访问 api.groq.com）==========
# 1) 打开 https://console.groq.com/keys 注册并创建 API Key（以 gsk- 开头）
# 2) 取消下面三行注释，并填上你的 Groq Key；同时注释掉上面「方案 1」三行，避免混用
# OPENAI_BASE_URL=https://api.groq.com/openai/v1
# OPENAI_API_KEY=gsk_你的groq密钥
# MODEL=llama-3.1-8b-instant

# ========== 方案 3：Ollama（本机免费，不花 API 钱；需自己安装 Ollama 并拉模型）==========
# 1) 安装：https://ollama.com  然后执行：ollama pull llama3.2:3b
# 2) MODEL 必须与「ollama list」第一列完全一致（常见错误：只写 llama3.2，实际本机是 llama3.2:3b）
# 3) 保持 Ollama 在后台运行，取消下面三行注释，并注释掉「方案 1」
# OPENAI_BASE_URL=http://127.0.0.1:11434/v1
# OPENAI_API_KEY=ollama
# MODEL=llama3.2:3b
